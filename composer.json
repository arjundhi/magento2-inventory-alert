{
    "name": "arjundhi/magento2-inventory-alert",
    "description": "Magento 2 module that monitors inventory thresholds and delivers scheduled low-stock digest emails to administrators.",
    "type": "magento2-module",
    "license": "MIT",
    "keywords": [
        "magento2",
        "inventory",
        "stock-alert",
        "admin-email",
        "cron",
        "rameera"
    ],
    "support": {
        "issues": "https://github.com/arjundhi/magento2-inventory-alert/issues",
        "source": "https://github.com/arjundhi/magento2-inventory-alert"
    },
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3 || ^8.4",
        "magento/framework": "^103.0",
        "magento/module-catalog": "^104.0",
        "magento/module-catalog-inventory": "^100.4",
        "magento/module-email": "^101.1",
        "magento/module-reports": "^101.2"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Rameera\\LowStockNotification\\": ""
        }
    },
    "extra": {
        "map": [
            [
                "*",
                "Rameera/LowStockNotification"
            ]
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
